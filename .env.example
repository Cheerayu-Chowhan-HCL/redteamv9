# RedTeam V9 — Environment Configuration Template
# Copy this to .env and fill in your values

MCP_BEARER_TOKEN=your-bearer-token-here
MCP_URL=http://127.0.0.1:6019/mcp
MCP_EXTERNAL_URL=http://YOUR_VM_IP:6019/mcp
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your-neo4j-password
OPENAI_API_KEY=your-openai-key-here
AZURE_OPENAI_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=your-azure-endpoint-here
